# Copier vers .env.local en local : https://supabase.com/dashboard/project/_/settings/api
# Sur Vercel : Project → Settings → Environment Variables (Production + Preview)

# --- Obligatoires (app + auth + realtime) ---
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_cle_anon_publique

# --- Recommandé en production (SEO, PWA, métadonnées, liens push) ---
# URL canonique sans slash final, ex. https://carte-fidelite.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- OneSignal Web Push ---
NEXT_PUBLIC_ONESIGNAL_APP_ID=votre_app_id_onesignal
ONESIGNAL_REST_API_KEY=votre_rest_api_key
# Dashboard OneSignal → Settings → Keys & IDs (App API Key, préfixe os_v2_app_…)
# En-tête API : Authorization: Key <clé> — pas Bearer. Pas de guillemets dans la valeur.
# DEBUG_ONESIGNAL=1  # logs serveur : présence env + longueur clé (jamais la clé)

# --- Cron Vercel (push outbox + rappels créneaux) ---
CRON_SECRET=generer_une_chaine_longue_aleatoire
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key
# Service role : Supabase → Settings → API (ne jamais exposer côté client)

# --- Optionnel (logs terminal uniquement, ne pas activer en prod) ---
# DEBUG_ADMIN_ROLE=1

# --- Supabase Auth (dashboard, pas dans Vercel) ---
# Authentication → URL Configuration :
#   Site URL = NEXT_PUBLIC_SITE_URL
#   Redirect URLs = https://votre-domaine.vercel.app/** , http://localhost:3000/**
#
# --- Supabase CLI (local uniquement) ---
# SUPABASE_ACCESS_TOKEN=
# npx supabase link --project-ref ... -p "..."
